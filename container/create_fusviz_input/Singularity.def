Bootstrap: docker
From: python:3.11-slim

%files
    ../../scripts/create_fusviz_input.py /app/create_fusviz_input.py
    pyproject.toml /app/pyproject.toml
    ../../examples/prepare_fusviz_tables/pcg_hg19.tab /app/data/pcg_hg19.tab

%post
    set -ex
    apt-get update && apt-get install -y --no-install-recommends curl ca-certificates

    # Install uv
    curl -LsSf https://astral.sh/uv/install.sh | sh
    export PATH="/root/.local/bin:$PATH"

    # Install dependencies using uv
    cd /app
    /root/.local/bin/uv pip install --system -r pyproject.toml

%environment
    export PATH="/root/.local/bin:$PATH"
    export PYTHONPATH=/app
    export GENE_COORD_FILE=/app/data/pcg_hg19.tab

%runscript
    exec python /app/create_fusviz_input.py --gene_coord "$GENE_COORD_FILE" "$@"